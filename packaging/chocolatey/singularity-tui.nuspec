<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>singularity-tui</id>
    <version>0.7.1</version>
    <packageSourceUrl>https://github.com/jmamda/singularity-tui</packageSourceUrl>
    <owners>singularity-tui</owners>
    <title>Singularity CLI</title>
    <authors>Singularity contributors</authors>
    <projectUrl>https://github.com/jmamda/singularity-tui</projectUrl>
    <licenseUrl>https://github.com/jmamda/singularity-tui/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/jmamda/singularity-tui</projectSourceUrl>
    <docsUrl>https://github.com/jmamda/singularity-tui#readme</docsUrl>
    <bugTrackerUrl>https://github.com/jmamda/singularity-tui/issues</bugTrackerUrl>
    <tags>cli tui ai llm anthropic openai opencode dispatcher</tags>
    <summary>Code-red TUI dispatcher for AI coding CLIs</summary>
    <description>
Singularity CLI is a terminal app that lets you race, vote, relay, and plan across multiple AI coding CLIs from a single prompt bar. A war-room, not a chat. Includes an opt-in governance layer (capability tokens, sentinel veto, dual-key handoff, shadow journal, trust decay).
    </description>
    <dependencies>
      <dependency id="nodejs" version="20.0.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
