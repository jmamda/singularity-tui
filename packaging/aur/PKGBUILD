# Maintainer: singularity-tui contributors
pkgname=singularity-tui
pkgver=0.7.1
pkgrel=1
pkgdesc='Code-red TUI dispatcher for AI coding CLIs'
arch=('any')
url='https://github.com/jmamda/singularity-tui'
license=('MIT')
depends=('nodejs>=20')
makedepends=('npm')
source=("https://registry.npmjs.org/${pkgname}/-/${pkgname}-${pkgver}.tgz")
sha256sums=('b598360282a3af4773d8890bc2f8b2c3c002da37a93d09f69d0bb7f84d5a06b9')

package() {
  npm install -g --prefix "${pkgdir}/usr" "${srcdir}/${pkgname}-${pkgver}.tgz"
  install -Dm644 "${pkgdir}/usr/lib/node_modules/${pkgname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
