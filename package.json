{
  "name": "singularity-cli",
  "version": "0.6.0",
  "description": "Code-red TUI dispatcher for AI coding CLIs (Claude Code, OpenCode, Codex, Antigravity) with LangGraph workflow monitoring.",
  "type": "module",
  "bin": {
    "singularity": "./dist/cli.js",
    "scli": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "wizard": "tsx src/cli.tsx wizard",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" && npm run typecheck",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "PATTERNS.md",
    "CONTROL.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "LICENSE",
    "examples"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "ink": "^7.0.3",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
