{
  "name": "singularity-tui",
  "version": "0.7.1",
  "description": "Code-red TUI dispatcher for AI coding CLIs (Claude Code, OpenCode, Codex, Antigravity) with LangGraph workflow monitoring.",
  "type": "module",
  "bin": {
    "singularity": "dist/cli.js",
    "scli": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "wizard": "tsx src/cli.tsx wizard",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" && eslint src && npm run typecheck",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "sync-packaging": "node scripts/sync-packaging.mjs",
    "version-packages": "changeset version && node scripts/sync-packaging.mjs",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmamda/singularity-tui.git"
  },
  "bugs": "https://github.com/jmamda/singularity-tui/issues",
  "homepage": "https://github.com/jmamda/singularity-tui#readme",
  "keywords": [
    "cli",
    "tui",
    "ink",
    "ai",
    "agents",
    "multi-agent",
    "claude",
    "codex",
    "opencode",
    "dispatcher",
    "mcp"
  ],
  "files": [
    "dist",
    "README.md",
    "PATTERNS.md",
    "CONTROL.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "LICENSE",
    "examples"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "ink": "^7.0.3",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.7"
  }
}
